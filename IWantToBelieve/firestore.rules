rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regras para a coleção de usuários
    match /users/{userId} {
      // Qualquer usuário autenticado pode ler perfis
      allow read: if request.auth != null;
      // Apenas o próprio usuário pode criar/editar seu perfil
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para a coleção de posts
    match /posts/{postId} {
      // Qualquer usuário autenticado pode ler os posts
      allow read: if request.auth != null;
      // Qualquer usuário autenticado pode criar um post
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Apenas o autor pode editar ou deletar seu próprio post
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
